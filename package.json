{
  "name": "glyphs",
  "version": "0.1.0",
  "private": true,
  "description": "cozy keyboard playground in a CRT terminal shell",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test-audio": "electron . --dev --audio-test",
    "gen-clips": "python3 tools/tts/generate_clips.py",
    "verify-clips": "python3 tools/tts/verify_clips.py",
    "test-phonemes": "python3 tools/tts/test_phonemes.py",
    "test-g2p": "node g2p/test_g2p.js"
  },
  "devDependencies": {
    "electron": "^42.4.0"
  },
  "dependencies": {
    "espeak-ng": "^1.0.2"
  }
}
